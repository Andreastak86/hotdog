---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import FeatureList from "../components/FeatureList.astro";
import CommunityGallery from "../components/CommunityGallery.astro";
import CtaBanner from "../components/CtaBanner.astro";
import PartnerSection from "../components/PartnerSection.astro";
import VideoSection from "../components/VideoSection.astro";
import Footer from "../components/Footer.astro";

const features = [
    {
        title: "Gjennomarbeidede oppskrifter",
        text: "Oppskriftene er laget for å være fine å se på, men også god å bruke. Dette er plagg for ekte hundeliv. Strikket med raglan – fra hals til hale i ett stykke, helt uten montering. Det gir en myk, fleksibel passform og god bevegelsesfrihet for hunden.",
    },
    {
        title: "Passform med personlighet",
        text: "Her handler det ikke bare om å holde hunden varm, men om å lage noe som faktisk ser skikkelig fint ut også. Alle genserne tar utgangspunkt i en basisoppskrift som gjør det enkelt å finne en god passform, uansett om hunden din er lang, kort, bred, slank – eller noe midt imellom. Når du først har funnet passformen som passer din hund, kan du strikke hvilken som helst av genserne i boken – uten å starte helt på nytt hver gang.",
    },
    {
        title: "Et levende fellesskap",
        text: "HOTDOG hundestrikk på Facebook er en gruppe hvor vi deler bilder av hundene våre med (og uten) genser, inspirasjon, tips og masse strikkeglede! Alle gensere er velkommen her, ikke bare HOTDOG-gensere.",
    },

    {
        title: "Steg for steg",
        text: "Basisoppskriften finnes også som en egen steg-for-steg-variant med bilder for deg som ønsker litt ekstra veiledning.",
    },
];

const galleryItems = [
    {
        src: "/dog1.png",
        alt: "Hund i grønn strikkegenser ute i naturen",
    },
    {
        src: "/dog2.png",
        alt: "Liten hund i strikket genser",
    },
    {
        src: "/dog3.png",
        alt: "Hund med mønstret genser",
    },
    {
        src: "/dog4.png",
        alt: "Hund i lys genser",
    },
    {
        src: "/dog5.png",
        alt: "Hund i lys genser",
    },
    {
        src: "/dog6.png",
        alt: "Hund i lys genser",
    },
    {
        src: "/dog7.png",
        alt: "Hund i lys genser",
    },
];
---

<BaseLayout title='HOTDOG Hundestrikk'>
    <main>
        <Hero
            eyebrow='Strikkeoppskrifter til hund'
            text='En sjarmerende og gjennomført bok for deg som vil strikke plagg med personlighet, god passform og varme. Oppdag HOTDOG-universet – og bli med i et fellesskap fullt av hunder, ull og stor skaperglede.'
            imageSrc='/book-cover.jpg'
            imageAlt='Forsiden på HOTDOG Hundestrikk'
            primaryHref='https://ebok.no/eboker/hobby-og-fritid/hotdog-elin-takvam/'
            primaryLabel='Kjøp e-boken'
            primaryNewTab={true}
            secondaryHref='https://www.facebook.com/groups/653163954334182'
            secondaryLabel='Bli med i Facebook-gruppen'
            secondaryNewTab={true}
            badgeText='Strikket med kjærlighet'
        />

        <FeatureList
            eyebrow='Hvorfor folk elsker HOTDOG'
            title='Mer enn bare oppskrifter'
            text='Dette handler ikke bare om masker og mønster. Det handler om å lage noe varmt, morsomt og personlig til en bestevenn med pels.'
            items={features}
        />
        <VideoSection
            eyebrow='Fra virkeligheten'
            title='Se hundene i aksjon'
            text='Oppskriftene lever ikke bare på papir – de brukes hver dag av hunder som både fryser og fortjener å se bra ut.'
            src='/video.mp4'
        />
        <PartnerSection
            eyebrow='Bestill ferdig strikket genser!'
            title='Linns Ullunivers'
            text='For deg som elsker hundegensere, men ikke nødvendigvis elsker å telle masker en tirsdag kveld.'
            name='Linns Ullunivers'
            description='Kan du ikke strikke selv, eller kanskje tiden ikke strekker til? Fortvil ikke! Du kan bestille gensere etter hundens mål hos Linns ullunivers! Hun er teststrikker til neste bok og kjenner disse oppskriftene ut og inn. Hun strikker etter hundens mål og har mange fornøyde kunder —både med og uten pels! Du finner henne på FB og Instagram'
            href='https://www.facebook.com/profile.php?id=61577422055000'
            linkLabel='Besøk Linns Ullunivers'
            imageSrc='/linnhund.jpg'
            imageAlt='Hund i håndstrikket genser fra Linns Ullunivers'
        />

        <CommunityGallery
            eyebrow='Fra fellesskapet'
            title='Delt av strikkeglade hundemennesker'
            text='I Facebook-gruppen deles gensere, erfaringer, spørsmål og bilder av hunder som ser ut som de vet at de er hovedpersonen. Det gjør hele HOTDOG-universet levende.'
            items={galleryItems}
            ctaHref='https://www.facebook.com/groups/653163954334182'
            ctaLabel='Bli med i Facebook-gruppa'
            secondaryCtaHref='https://www.instagram.com/hotdog_hundestrikk/'
            secondaryCtaLabel='Følg på Instagram'
        />

        <CtaBanner
            eyebrow='Ny bok i høst!'
            title='Bok nummer to kommer på forlag'
            text='Det som startet som en populær e-bok, vokser nå videre til en ny bokutgivelse på forlag. Kjøp den første boken i dag, og bli med i fellesskapet for å følge reisen videre.'
            primaryHref='https://ebok.no/eboker/hobby-og-fritid/hotdog-elin-takvam/'
            primaryLabel='Kjøp e-boken'
            secondaryHref='https://www.facebook.com/groups/653163954334182'
            secondaryLabel='Følg lanseringen i gruppen'
        />
    </main>
    <Footer
        brand='HOTDOG Hundestrikk'
        text='En varm og gjennomført bok for strikkeglade hundemennesker.'
        shopHref='https://ebok.no/eboker/hobby-og-fritid/hotdog-elin-takvam/'
        facebookHref='https://www.facebook.com/groups/653163954334182'
        instagramHref='https://www.instagram.com/hotdog_hundestrikk/'
        partnerHref='https://www.facebook.com/profile.php?id=61577422055000'
    />
</BaseLayout>
