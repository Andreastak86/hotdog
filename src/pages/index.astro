---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import FeatureList from "../components/FeatureList.astro";
import CommunityGallery from "../components/CommunityGallery.astro";
import CtaBanner from "../components/CtaBanner.astro";
import PartnerSection from "../components/PartnerSection.astro";
import VideoSection from "../components/VideoSection.astro";
import Footer from "../components/Footer.astro";

const features = [
    {
        title: "Gjennomarbeidede oppskrifter",
        text: "Alle genserne tar utgangspunkt i en basisoppskrift som gjør det enkelt å finne en god passform, uansett om hunden din er lang, kort, bred, slank – eller noe midt imellom. Når du først har funnet riktig passform til din hund, kan du strikke hvilken som helst av genserne i boken – uten å starte helt på nytt hver gang. Genserne er strikket med raglan – fra hals til hale i ett stykke, helt uten montering. Basisoppskriften finnes også som en egen steg-for-steg-variant med bilder for deg som ønsker litt ekstra veiledning.",
    },
    {
        title: "Passform med personlighet",
        text: "Dette er plagg for ekte hundeliv! Genserne er laget for å være fine å se på, men også gode å bruke. De er strikket med raglan og elastiske ribber, noe som gir en myk og fleksibel passform, samt god bevegelsesfrihet for hunden.",
    },
    {
        title: "Et levende fellesskap",
        text: "HOTDOG hundestrikk på Facebook er en gruppe hvor vi deler bilder av hundene våre – med (og uten) genser, inspirasjon, tips og masse strikkeglede! Alle gensere er velkomne her, ikke bare HOTDOG-gensere.",
        href: "https://www.facebook.com/groups/653163954334182",
        label: "Bli med i Facebook-gruppen",
        newTab: true,
    },
];

const galleryItems = [
    {
        src: "/dog1.png",
        alt: "Hund i grønn strikkegenser ute i naturen",
    },
    {
        src: "/dog2.png",
        alt: "Liten hund i strikket genser",
        featured: true,
    },
    {
        src: "/dog4.png",
        alt: "Hund i lys genser",
    },
    {
        src: "/dog8.png",
        alt: "Gensre med mange mønstre og farger",
    },
    {
        src: "/dog9.png",
        alt: "Hund i lys genser",
    },
    {
        src: "/dog6.png",
        alt: "Hund i lys genser",
    },
    {
        src: "/dog7.png",
        alt: "Hund i lys genser",
    },
];

const upcomingGalleryItems = [
    {
        src: "/dog10.png",
        alt: "Hund i ny HOTDOG-genser fra kommende bok",
    },
    {
        src: "/dog11.png",
        alt: "Detalj av strikket hundegenser",
        featured: true,
    },
    {
        src: "/dog12.png",
        alt: "Hund i fargerik genser",
    },
    {
        src: "/dog13.png",
        alt: "Hund i mønstret genser",
    },
];
---

<BaseLayout
    title='Hundegenser.no | HOTDOG Hundestrikk – strikkeoppskrifter til hund'
    description='Oppdag HOTDOG Hundestrikk – varme og gjennomførte strikkeoppskrifter til hund. Kjøp e-boken, bli med i Facebook-gruppen og følg lanseringen av bok nummer to.'
>
    <main>
        <Hero
            eyebrow='Strikkeoppskrifter til hund'
            text='En sjarmerende og gjennomført bok for deg som vil strikke plagg med personlighet, god passform og varme. Oppdag HOTDOG-universet – og bli med i et fellesskap fullt av hunder, ull og stor skaperglede.'
            imageSrc='/book-cover.jpg'
            imageAlt='Forsiden på HOTDOG Hundestrikk'
            primaryHref='https://ebok.no/eboker/hobby-og-fritid/hotdog-elin-takvam/'
            primaryLabel='Kjøp e-boken'
            primaryNewTab={true}
            secondaryHref='https://www.facebook.com/groups/653163954334182'
            secondaryLabel='Bli med i Facebook-gruppen'
            secondaryNewTab={true}
            badgeText='Strikket med kjærlighet'
        />

        <FeatureList
            eyebrow='Hvorfor folk elsker HOTDOG'
            title='Mer enn bare oppskrifter'
            text='Dette handler ikke bare om masker og mønster. Det handler om å lage noe varmt, morsomt og personlig til en bestevenn med pels.'
            items={features}
        />

        <VideoSection
            eyebrow='Fra neste HOTDOG-bok'
            title='Se hundene i aksjon'
            text='Oppskriftene lever ikke bare på papir – de brukes hver dag av hunder som både fryser og fortjener å se bra ut.'
            src='/video.mp4'
        />

        <PartnerSection
            eyebrow='Bestill ferdig strikket genser!'
            title='Linns Ullunivers'
            text='For deg som elsker hundegensere, men ikke nødvendigvis elsker å telle masker en tirsdag kveld.'
            name='Linns Ullunivers'
            description='Kan du ikke strikke selv, eller kanskje tiden ikke strekker til? Fortvil ikke! Du kan bestille gensere etter hundens mål hos Linns ullunivers! Hun er teststrikker til neste bok og kjenner disse oppskriftene inn og ut, og har mange fornøyde kunder — både med og uten pels! Du finner henne på Facebook og Instagram'
            primaryHref='https://www.facebook.com/profile.php?id=61577422055000'
            primaryLabel='Facebook'
            secondaryHref='https://www.instagram.com/linnsullunivers/'
            secondaryLabel='Instagram'
            imageSrc='/linnhund.jpg'
            imageAlt='Hund i håndstrikket genser fra Linns Ullunivers'
        />

        <CommunityGallery
            class='community-gallery--upcoming'
            eyebrow='Fra fellesskapet'
            title='Delt av strikkeglade hundemennesker'
            text='I Facebook-gruppen deles bilder av hunder i genser, erfaringer og spørsmål – og ikke minst bilder av hunder som ser ut som de vet at de er hovedpersonen. Det er det som gjør hele HOTDOG-universet levende.'
            items={galleryItems}
            ctaHref='https://www.facebook.com/groups/653163954334182'
            ctaLabel='Bli med i Facebook-gruppen'
            ctaNewTab={true}
            secondaryCtaHref='https://www.instagram.com/hotdog_hundestrikk/'
            secondaryCtaLabel='Følg på Instagram'
            secondaryCtaNewTab={true}
        />

        <CtaBanner
            eyebrow='Ny bok i høst'
            title='En ny bok er på vei!'
            text='HOTDOG vokser videre. En helt ny bok er nå på vei til forlag, med enda flere oppskrifter, historier og varme plagg til firbente favoritter. Den er ikke i salg ennå – men du kan bli med bak kulissene og følge reisen frem mot lansering.'
            secondaryHref='https://www.facebook.com/groups/653163954334182'
            secondaryLabel='Følg lanseringen'
            secondaryNewTab={true}
        />

        <CommunityGallery
            class='community-gallery--upcoming'
            eyebrow='Et lite glimt av det som kommer'
            title='Gensere fra den nye boken'
            text='Her er noen av genserne som kommer i neste bok av HOTDOG. Flere modeller er på vei, og boken er ikke i salg ennå.'
            items={upcomingGalleryItems}
        />
    </main>

    <Footer
        brand='HOTDOG av Elin Takvam'
        text='En varm og gjennomført bok for strikkeglade hundemennesker.'
        shopHref='https://ebok.no/eboker/hobby-og-fritid/hotdog-elin-takvam/'
        facebookHref='https://www.facebook.com/groups/653163954334182'
        instagramHref='https://www.instagram.com/hotdog_hundestrikk/'
        partnerFacebookHref='https://www.facebook.com/profile.php?id=61577422055000'
        partnerInstagramHref='https://www.instagram.com/linnsullunivers/'
    />
</BaseLayout>
