---
import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
}

const {
    title = "HOTDOG Hundestrikk",
    description = "Varme gensere for kalde hunder. Strikkeoppskrifter til hund og et levende fellesskap for strikkeglade hundemennesker.",
} = Astro.props;
---

<!doctype html>
<html lang='no'>
    <head>
        <meta charset='UTF-8' />
        <meta name='viewport' content='width=device-width, initial-scale=1.0' />
        <title>{title}</title>
        <meta name='description' content={description} />
        <link rel='preconnect' href='https://fonts.googleapis.com' />
        <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
        <link
            href='https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,700;6..72,800&family=Work+Sans:wght@400;500;600;700&display=swap'
            rel='stylesheet'
        />
    </head>
    <body>
        <slot />
    </body>
</html>
