---
import SectionHeading from "./SectionHeading.astro";

interface Props {
    eyebrow?: string;
    title: string;
    text?: string;
    name: string;
    description: string;
    href: string;
    linkLabel?: string;
    imageSrc?: string;
    imageAlt?: string;
    newTab?: boolean;
}

const {
    eyebrow,
    title,
    text,
    name,
    description,
    href,
    linkLabel = "Besøk siden",
    imageSrc,
    imageAlt = "",
    newTab = true,
} = Astro.props;
---

<section class='section'>
    <div class='container'>
        <div class='partner-section'>
            <div class='partner-section__content'>
                <SectionHeading eyebrow={eyebrow} title={title} text={text} />

                <div class='partner-card'>
                    <p class='partner-card__name'>{name}</p>
                    <p class='partner-card__description'>{description}</p>

                    <a
                        href={href}
                        class='button button--primary'
                        target={newTab ? "_blank" : undefined}
                        rel={newTab ? "noopener noreferrer" : undefined}
                    >
                        {linkLabel}
                    </a>
                </div>
            </div>

            {
                imageSrc && (
                    <div class='partner-section__visual'>
                        <div class='partner-section__image-frame'>
                            <img
                                src={imageSrc}
                                alt={imageAlt}
                                class='partner-section__image'
                                loading='lazy'
                            />
                        </div>
                    </div>
                )
            }
        </div>
    </div>
</section>
