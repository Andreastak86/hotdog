---
import SectionHeading from "./SectionHeading.astro";

interface Props {
    eyebrow?: string;
    title: string;
    text?: string;
    name: string;
    description: string;

    primaryHref: string;
    primaryLabel?: string;
    primaryNewTab?: boolean;

    secondaryHref?: string;
    secondaryLabel?: string;
    secondaryNewTab?: boolean;

    imageSrc?: string;
    imageAlt?: string;
}

const {
    eyebrow,
    title,
    text,
    name,
    description,

    primaryHref,
    primaryLabel = "Besøk siden",
    primaryNewTab = true,

    secondaryHref,
    secondaryLabel,
    secondaryNewTab = true,

    imageSrc,
    imageAlt = "",
} = Astro.props;
---

<section class='section'>
    <div class='container'>
        <div class='partner-section'>
            <div class='partner-section__content'>
                <SectionHeading eyebrow={eyebrow} title={title} text={text} />

                <div class='partner-card'>
                    <p class='partner-card__name'>{name}</p>
                    <p class='partner-card__description'>{description}</p>

                    <div class='partner-actions'>
                        <a
                            href={primaryHref}
                            class='button button--primary'
                            target={primaryNewTab ? "_blank" : undefined}
                            rel={primaryNewTab
                                ? "noopener noreferrer"
                                : undefined}
                        >
                            {primaryLabel}
                        </a>

                        {
                            secondaryHref && secondaryLabel && (
                                <a
                                    href={secondaryHref}
                                    class='button button--secondary'
                                    target={
                                        secondaryNewTab ? "_blank" : undefined
                                    }
                                    rel={
                                        secondaryNewTab
                                            ? "noopener noreferrer"
                                            : undefined
                                    }
                                >
                                    {secondaryLabel}
                                </a>
                            )
                        }
                    </div>
                </div>
            </div>

            {
                imageSrc && (
                    <div class='partner-section__visual'>
                        <div class='partner-section__image-frame'>
                            <img
                                src={imageSrc}
                                alt={imageAlt}
                                class='partner-section__image'
                                loading='lazy'
                            />
                        </div>
                    </div>
                )
            }
        </div>
    </div>
</section>
