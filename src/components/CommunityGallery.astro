---
import SectionHeading from "./SectionHeading.astro";

interface GalleryItem {
    src: string;
    alt: string;
    featured?: boolean;
}

interface Props {
    eyebrow?: string;
    title: string;
    text?: string;
    items: GalleryItem[];
    ctaHref?: string;
    ctaLabel?: string;
    ctaNewTab?: boolean;
    secondaryCtaHref?: string;
    secondaryCtaLabel?: string;
    secondaryCtaNewTab?: boolean;
    class?: string;
}

const {
    eyebrow,
    title,
    text,
    items = [],
    ctaHref,
    ctaLabel,
    ctaNewTab = true,
    secondaryCtaHref,
    secondaryCtaLabel,
    secondaryCtaNewTab = true,
    class: sectionClass = "",
} = Astro.props;
---

<section class:list={["section section--soft", sectionClass]}>
    <div class='container'>
        <SectionHeading eyebrow={eyebrow} title={title} text={text} />

        <div class='community-grid'>
            {
                items.map((item) => (
                    <figure
                        class:list={[
                            "community-card",
                            item.featured && "community-card--featured",
                        ]}
                    >
                        <img src={item.src} alt={item.alt} loading='lazy' />
                    </figure>
                ))
            }
        </div>

        {
            (ctaHref || secondaryCtaHref) && (
                <div class='community-actions'>
                    {ctaHref && ctaLabel && (
                        <a
                            href={ctaHref}
                            class='button button--secondary'
                            target={ctaNewTab ? "_blank" : undefined}
                            rel={ctaNewTab ? "noopener noreferrer" : undefined}
                        >
                            {ctaLabel}
                        </a>
                    )}

                    {secondaryCtaHref && secondaryCtaLabel && (
                        <a
                            href={secondaryCtaHref}
                            class='button button--secondary'
                            target={secondaryCtaNewTab ? "_blank" : undefined}
                            rel={
                                secondaryCtaNewTab
                                    ? "noopener noreferrer"
                                    : undefined
                            }
                        >
                            {secondaryCtaLabel}
                        </a>
                    )}
                </div>
            )
        }
    </div>
</section>
