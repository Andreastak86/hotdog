---
import SectionHeading from "./SectionHeading.astro";

interface FeatureItem {
    title: string;
    text: string;
    href?: string;
    label?: string;
}

interface Props {
    eyebrow?: string;
    title: string;
    text?: string;
    items: FeatureItem[];
}

const { eyebrow, title, text, items = [] } = Astro.props;
---

<section class='section'>
    <div class='container'>
        <SectionHeading eyebrow={eyebrow} title={title} text={text} />

        <div class='feature-grid'>
            {
                items.map((item) => (
                    <article class='feature-card'>
                        <h3>{item.title}</h3>
                        <p>{item.text}</p>

                        {item.href && item.label && (
                            <a
                                href={item.href}
                                class='button button--primary feature-card__button'
                                target='_blank'
                                rel='noopener noreferrer'
                            >
                                {item.label}
                            </a>
                        )}
                    </article>
                ))
            }
        </div>
    </div>
</section>
