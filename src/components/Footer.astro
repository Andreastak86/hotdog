---
interface Props {
    brand?: string;
    text?: string;

    facebookHref?: string;
    instagramHref?: string;
    shopHref?: string;

    partnerFacebookHref?: string;
    partnerInstagramHref?: string;
}

const {
    brand = "HOTDOG",
    text = "Varme gensere for kalde hunder.",

    facebookHref,
    instagramHref,
    shopHref,

    partnerFacebookHref,
    partnerInstagramHref,
} = Astro.props;

const year = new Date().getFullYear();
---

<footer class='site-footer'>
    <div class='container site-footer__inner'>
        <div class='site-footer__brand'>
            <h2>HOTDOG</h2>
            <p>{text}</p>
        </div>

        <nav class='site-footer__nav' aria-label='Footer'>
            {
                shopHref && (
                    <a
                        href={shopHref}
                        target='_blank'
                        rel='noopener noreferrer'
                    >
                        Kjøp e-boken
                    </a>
                )
            }

            {
                facebookHref && (
                    <a
                        href={facebookHref}
                        target='_blank'
                        rel='noopener noreferrer'
                    >
                        Facebook-gruppe
                    </a>
                )
            }

            {
                instagramHref && (
                    <a
                        href={instagramHref}
                        target='_blank'
                        rel='noopener noreferrer'
                    >
                        Følg på Instagram
                    </a>
                )
            }

            {
                (partnerFacebookHref || partnerInstagramHref) && (
                    <>
                        {partnerFacebookHref && (
                            <a
                                href={partnerFacebookHref}
                                target='_blank'
                                rel='noopener noreferrer'
                            >
                                Linns Ullunivers på Facebook
                            </a>
                        )}

                        {partnerInstagramHref && (
                            <a
                                href={partnerInstagramHref}
                                target='_blank'
                                rel='noopener noreferrer'
                            >
                                Linns Ullunivers på Instagram
                            </a>
                        )}
                    </>
                )
            }
        </nav>
    </div>

    <div class='container site-footer__bottom'>
        <p>© {year} {brand}</p>

        <p class='site-footer__credit'>
            Laget av
            <a
                href='https://din-portfolio.no'
                target='_blank'
                rel='noopener noreferrer'
            >
                lillebror - Andreas Takvam
            </a>
        </p>
    </div>
</footer>
