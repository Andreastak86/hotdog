---
interface Props {
    eyebrow?: string;
    title: string;
    highlight?: string;
    text: string;
    imageSrc: string;
    imageAlt: string;
    primaryHref: string;
    primaryLabel: string;
    secondaryHref?: string;
    secondaryLabel?: string;
    badgeText?: string;
}

const {
    eyebrow,
    title,
    highlight,
    text,
    imageSrc,
    imageAlt,
    primaryHref,
    primaryLabel,
    secondaryHref,
    secondaryLabel,
    badgeText = "Strikket med kjærlighet",
} = Astro.props;

const titleParts =
    highlight && title.includes(highlight) ? title.split(highlight) : null;
---

<section class='hero'>
    <div class='container hero__grid'>
        <div class='hero__content'>
            {eyebrow && <span class='eyebrow'>{eyebrow}</span>}

            <h1 class='hero__title'>
                {
                    titleParts ? (
                        <>
                            {titleParts[0]}
                            <span class='accent'>{highlight}</span>
                            {titleParts[1]}
                        </>
                    ) : (
                        title
                    )
                }
            </h1>

            <p class='lead'>{text}</p>

            <div class='hero__actions'>
                <a href={primaryHref} class='button button--primary'>
                    {primaryLabel}
                </a>

                {
                    secondaryHref && secondaryLabel && (
                        <a
                            href={secondaryHref}
                            class='button button--secondary'
                        >
                            {secondaryLabel}
                        </a>
                    )
                }
            </div>
        </div>

        <div class='hero__visual'>
            <div class='hero__card'>
                <div class='hero__card-inner'>
                    <img src={imageSrc} alt={imageAlt} class='hero__image' />
                </div>

                {badgeText && <div class='badge-note'>{badgeText}</div>}
            </div>
        </div>
    </div>
</section>
